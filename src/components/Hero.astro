---
import Photo from "./Photo.astro";
---

<section class="hero" id="top">
  <div class="container hero__grid">
    <div class="hero__copy">
      <div class="hero__stamp" aria-hidden="true">
        <svg viewBox="0 0 180 60" width="180" height="60">
          <rect x="2" y="2" width="176" height="56" rx="6" fill="none" stroke="#c25a3f" stroke-width="1.5" stroke-dasharray="2 3"/>
          <text x="90" y="26" text-anchor="middle" font-family="Manrope, sans-serif" font-size="10" font-weight="700" letter-spacing="2" fill="#c25a3f">HEUTE GEÖFFNET</text>
          <text x="90" y="44" text-anchor="middle" font-family="Manrope, sans-serif" font-size="9" letter-spacing="1" fill="#c25a3f">14:00 — 21:00 · MÖNKESWEG 58</text>
        </svg>
      </div>

      <p class="hero__eyebrow">Jugendcafé · Meerbusch · seit 2026</p>

      <h1 class="hero__title">
        <span class="hero__line-1">Ein zweites</span>
        <span class="hero__line-2">
          <span class="hero__word">Zuhause</span><span class="hero__sup">
            <svg viewBox="0 0 60 60" width="56" height="56" aria-hidden="true" class="hero__circle">
              <circle cx="30" cy="30" r="24" fill="none" stroke="#c25a3f" stroke-width="1.5" stroke-dasharray="3 4"/>
            </svg>
            <span class="hero__sup-num">2</span>
          </span>.
        </span>
        <span class="hero__line-3">Für alle, die eins brauchen.</span>
      </h1>

      <p class="hero__lead">
        Zwischen Schule und Schlaf, zwischen sechzehn und zu&shy;viel —
        wir machen einen Ort auf, an dem du <em>einfach sein</em> darfst.
        Kein Zwang. Kein Ticket. Nur ein Dach, das hält.
      </p>

      <div class="hero__ctas">
        <a href="#raeume" class="btn btn--primary">
          <span>Räume ansehen</span>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M2 8 H14 M9 3 L14 8 L9 13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#programm" class="btn btn--ghost">Programm diese Woche</a>
      </div>

      <dl class="hero__meta">
        <div>
          <dt>Adresse</dt>
          <dd>Mönkesweg 58 · 40670 Meerbusch</dd>
        </div>
        <div>
          <dt>Eintritt</dt>
          <dd>Immer frei. Immer.</dd>
        </div>
        <div>
          <dt>Für wen</dt>
          <dd>13 – 21 Jahre</dd>
        </div>
      </dl>
    </div>

    <div class="hero__photos" aria-hidden="true">
      <div class="hero__photo hero__photo--1">
        <span class="tape" style="top:-11px;left:30%;transform:rotate(-4deg)"></span>
        <Photo tone="warm" aspect="4/5" caption="Mittwoch, kurz vor sieben" alt="Licht im Gemeinschaftsraum, jemand mischt Karten" />
      </div>
      <div class="hero__photo hero__photo--2">
        <span class="tape" style="top:-9px;right:18%;transform:rotate(5deg)"></span>
        <Photo tone="ochre" aspect="1/1" caption="Milchkaffee, selbst bezahlt" alt="Tasse Milchkaffee mit Löffel auf Holztisch" />
      </div>
      <div class="hero__photo hero__photo--3">
        <Photo tone="cool" aspect="3/4" caption="Terrasse im April" alt="Gartenstühle im Halbschatten, Lichterkette über dem Beet" />
      </div>

      <svg class="hero__scribble" viewBox="0 0 120 40" aria-hidden="true">
        <path d="M5 20 C 25 5, 45 35, 65 18 S 105 25, 115 12" fill="none" stroke="#c25a3f" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </div>
  </div>

  <div class="hero__marquee" aria-hidden="true">
    <div class="hero__marquee-track">
      <span>Komm vorbei.</span><span class="dot">✦</span>
      <span>Bleib so lang du willst.</span><span class="dot">✦</span>
      <span>Das Wasser gibt’s kostenlos.</span><span class="dot">✦</span>
      <span>Niemand schaut auf die Uhr.</span><span class="dot">✦</span>
      <span>Komm vorbei.</span><span class="dot">✦</span>
      <span>Bleib so lang du willst.</span><span class="dot">✦</span>
      <span>Das Wasser gibt’s kostenlos.</span><span class="dot">✦</span>
      <span>Niemand schaut auf die Uhr.</span><span class="dot">✦</span>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(48px, 7vw, 96px) clamp(40px, 6vw, 80px);
    position: relative;
    overflow: hidden;
  }

  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: clamp(32px, 5vw, 88px);
    align-items: center;
  }

  .hero__copy {
    position: relative;
    animation: riseIn 900ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }

  .hero__stamp {
    position: absolute;
    top: -38px;
    right: -12px;
    left: auto;
    transform: rotate(-6deg);
    opacity: 0.9;
  }

  .hero__eyebrow {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--forest-soft);
    margin-bottom: 26px;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7.5vw, 5.8rem);
    line-height: 0.96;
    letter-spacing: -0.035em;
    font-weight: 400;
    color: var(--ink);
    font-variation-settings: "SOFT" 50, "WONK" 1, "opsz" 144;
  }

  .hero__line-1 {
    display: block;
    font-style: italic;
    font-weight: 300;
    color: var(--forest);
    font-size: 0.65em;
    margin-bottom: 4px;
    font-variation-settings: "SOFT" 100, "WONK" 1, "opsz" 144;
  }

  .hero__line-2 {
    display: block;
    position: relative;
  }

  .hero__word {
    font-weight: 500;
  }

  .hero__sup {
    display: inline-flex;
    position: relative;
    align-items: flex-start;
    margin-left: 4px;
    vertical-align: top;
  }

  .hero__circle {
    position: absolute;
    top: -10px;
    left: -8px;
    opacity: 0.7;
    animation: spin 40s linear infinite;
  }

  .hero__sup-num {
    position: relative;
    z-index: 1;
    color: var(--terracotta);
    font-style: italic;
    font-weight: 600;
    font-size: 0.56em;
    line-height: 1;
    margin-top: 0.08em;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .hero__line-3 {
    display: block;
    font-size: 0.48em;
    margin-top: 18px;
    color: var(--forest);
    font-weight: 300;
    letter-spacing: -0.01em;
    font-family: var(--font-display);
    font-style: italic;
    font-variation-settings: "SOFT" 100, "WONK" 0, "opsz" 144;
  }

  .hero__lead {
    margin-top: 32px;
    max-width: 48ch;
    font-size: 1.08rem;
    line-height: 1.65;
    color: var(--ink-soft);
  }

  .hero__lead em {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    color: var(--terracotta);
  }

  .hero__ctas {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 22px;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    transition: transform 200ms cubic-bezier(0.2, 0.8, 0.2, 1), background 200ms ease;
  }

  .btn--primary {
    background: var(--terracotta);
    color: var(--paper-soft);
    box-shadow: 0 10px 24px -10px rgba(194, 90, 63, 0.7);
  }

  .btn--primary:hover {
    background: var(--terracotta-deep);
    transform: translateY(-2px);
  }

  .btn--ghost {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--line);
    padding: 13px 20px;
  }

  .btn--ghost:hover {
    border-color: var(--forest);
    background: color-mix(in oklab, var(--forest) 6%, transparent);
  }

  .hero__meta {
    margin-top: 48px;
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: clamp(16px, 3vw, 44px);
    border-top: 1px dashed var(--line);
    padding-top: 22px;
  }

  .hero__meta > div {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .hero__meta dt {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--forest-soft);
  }

  .hero__meta dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: 0.98rem;
    color: var(--ink);
    font-variation-settings: "SOFT" 70, "WONK" 1;
  }

  /* photos */
  .hero__photos {
    position: relative;
    min-height: 540px;
    animation: riseIn 1100ms cubic-bezier(0.2, 0.8, 0.2, 1) 120ms both;
  }

  .hero__photo {
    position: absolute;
    width: 50%;
    transition: transform 500ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .hero__photo--1 {
    top: 0;
    left: 6%;
    width: 58%;
    transform: rotate(-4deg);
    z-index: 3;
  }
  .hero__photo--1:hover {
    transform: rotate(-2deg) translateY(-6px);
  }

  .hero__photo--2 {
    top: 38%;
    right: 0;
    width: 46%;
    transform: rotate(6deg);
    z-index: 2;
  }
  .hero__photo--2:hover {
    transform: rotate(3deg) translateY(-4px);
  }

  .hero__photo--3 {
    bottom: 0;
    left: 0;
    width: 42%;
    transform: rotate(-2deg);
    z-index: 1;
  }
  .hero__photo--3:hover {
    transform: rotate(0deg) translateY(-4px);
  }

  .hero__scribble {
    position: absolute;
    top: 52%;
    left: 42%;
    width: 110px;
    z-index: 4;
    opacity: 0.75;
    transform: rotate(-12deg);
  }

  /* marquee */
  .hero__marquee {
    margin-top: clamp(48px, 8vw, 100px);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: 16px;
    background: color-mix(in oklab, var(--paper-deep) 40%, transparent);
    overflow: hidden;
  }

  .hero__marquee-track {
    display: flex;
    gap: 40px;
    white-space: nowrap;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--forest);
    animation: marquee 42s linear infinite;
    font-variation-settings: "SOFT" 100, "WONK" 1;
  }

  .hero__marquee-track .dot {
    color: var(--terracotta);
    font-style: normal;
    font-size: 1rem;
    align-self: center;
  }

  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
    }
    .hero__photos {
      min-height: 480px;
      margin-top: 32px;
    }
    .hero__stamp {
      top: -28px;
      right: -8px;
    }
    .hero__meta {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
