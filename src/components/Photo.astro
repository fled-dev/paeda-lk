---
interface Props {
  src?: string;
  alt?: string;
  caption?: string;
  aspect?: string;
  tone?: "warm" | "cool" | "ochre" | "rose";
  rotate?: number;
  className?: string;
}

const {
  src,
  alt = "",
  caption,
  aspect = "4 / 5",
  tone = "warm",
  rotate = 0,
  className = "",
} = Astro.props;

const toneGradient: Record<string, string> = {
  warm:
    "radial-gradient(ellipse at 30% 30%, rgba(217,164,65,.28), transparent 55%), radial-gradient(ellipse at 75% 75%, rgba(194,90,63,.22), transparent 60%), linear-gradient(135deg, #e8d9b4, #f2e4c8)",
  cool:
    "radial-gradient(ellipse at 30% 30%, rgba(63,90,74,.22), transparent 55%), radial-gradient(ellipse at 75% 75%, rgba(42,61,51,.25), transparent 60%), linear-gradient(135deg, #c8d0c0, #e2e6d8)",
  ochre:
    "radial-gradient(ellipse at 35% 35%, rgba(217,164,65,.4), transparent 55%), linear-gradient(135deg, #e4c488, #ead29f)",
  rose:
    "radial-gradient(ellipse at 35% 35%, rgba(232,168,154,.4), transparent 55%), linear-gradient(135deg, #e8c4b9, #eccfc6)",
};
---

<figure class={`polaroid ${className}`} style={`--rot:${rotate}deg; transform:rotate(${rotate}deg); aspect-ratio:auto;`}>
  <div class="photo" style={`aspect-ratio:${aspect}; background-image:${toneGradient[tone]};`}>
    {src ? (
      <img src={src} alt={alt} loading="lazy" decoding="async" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:1;" />
    ) : (
      <span class="photo__label">{alt || caption || "Foto"}</span>
    )}
  </div>
  {caption && <figcaption class="polaroid__caption">{caption}</figcaption>}
</figure>
