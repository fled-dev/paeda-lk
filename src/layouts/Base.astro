---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Zuhause² — Jugendcafé in Meerbusch",
  description = "Zuhause² ist ein Jugendcafé in Meerbusch. Ein zweites Zuhause für alle, die eins brauchen. Räume zum Ankommen, Bleiben, Wiederkommen.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#f7efe0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
